{
  "id": "192a3f24-360a-4835-9990-d3db6c5a0af4",
  "scriptName": "命定核心-八云紫美化",
  "findRegex": "/<yukari name=\\\"(.*?)\\\"(?: mood=\\\"(.*?)\\\")?>([\\s\\S]*?)<\\/yukari>/g",
  "replaceString": "<div class=\"yk-box\" data-mood=\"$2\">\n  <div class=\"yk-gap-top\"></div>\n  <div class=\"yk-content\">\n    <div class=\"yk-header\">\n      <span class=\"yk-mood-eye\"></span>\n      <span class=\"yk-name\">$1</span>\n      <div class=\"yk-line\"></div>\n    </div>\n    <div class=\"yk-text\">$3</div>\n  </div>\n  <div class=\"yk-gap-bottom\"></div>\n</div>\n\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;600&display=swap');\n\n.yk-box {\n  --yk-main: #6B2D80;\n  --yk-accent: #C9A0DC;\n  --yk-ribbon: #B83B2E;\n  --yk-text: #EAE0F0;\n  --yk-deep: #0E0618;\n  --yk-eye-c: 0.3;\n\n  display: flex;\n  flex-direction: column;\n  position: relative;\n  margin: 14px 0;\n  border-radius: 4px;\n  overflow: hidden;\n  font-family: 'Shippori Mincho', 'Noto Serif SC', serif;\n  box-shadow: 0 2px 14px rgba(60,15,80,0.25);\n}\n\n/* mood overrides */\n.yk-box[data-mood=\\\"default\\\"]   { --yk-main: #6B2D80; --yk-accent: #C9A0DC; }\n.yk-box[data-mood=\\\"amused\\\"]    { --yk-main: #7E3D90; --yk-accent: #DDB8EE; }\n.yk-box[data-mood=\\\"scheming\\\"]  { --yk-main: #502068; --yk-accent: #A070B8; }\n.yk-box[data-mood=\\\"elegant\\\"]   { --yk-main: #5E2895; --yk-accent: #D8C0F0; --yk-ribbon: #C8A040; }\n.yk-box[data-mood=\\\"teasing\\\"]   { --yk-main: #8A3598; --yk-accent: #E8B8E0; }\n.yk-box[data-mood=\\\"surprised\\\"] { --yk-main: #884070; --yk-accent: #E8A0C8; }\n.yk-box[data-mood=\\\"nostalgic\\\"] { --yk-main: #5A2860; --yk-accent: #C8A0B8; --yk-ribbon: #9A6060; }\n.yk-box[data-mood=\\\"serious\\\"]   { --yk-main: #3A1050; --yk-accent: #8868A0; --yk-ribbon: #804030; }\n.yk-box[data-mood=\\\"pleased\\\"]   { --yk-main: #7A38A0; --yk-accent: #E0C0F8; --yk-ribbon: #D0A040; }\n.yk-box[data-mood=\\\"concerned\\\"] { --yk-main: #4A1860; --yk-accent: #A880B8; }\n.yk-box[data-mood=\\\"drowsy\\\"]    { --yk-main: #3A1848; --yk-accent: #9080A0; --yk-ribbon: #806858; }\n\n/* ===== 隙間 gap strip — top ===== */\n.yk-gap-top,\n.yk-gap-bottom {\n  height: 18px;\n  position: relative;\n  background: linear-gradient(90deg, #080310, #100820 30%, #0D0618 60%, #080310);\n  overflow: hidden;\n  flex-shrink: 0;\n}\n\n/* gap slit glow */\n.yk-gap-top::before,\n.yk-gap-bottom::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: radial-gradient(ellipse at center, rgba(100,40,140,0.2), transparent 70%);\n  pointer-events: none;\n}\n\n/* gap inner edge */\n.yk-gap-top::after {\n  content: '';\n  position: absolute;\n  left: 5%; right: 5%; bottom: 0;\n  height: 1.5px;\n  background: linear-gradient(90deg, transparent, var(--yk-accent) 15%, var(--yk-accent) 85%, transparent);\n  opacity: 0.5;\n}\n.yk-gap-bottom::after {\n  content: '';\n  position: absolute;\n  left: 5%; right: 5%; top: 0;\n  height: 1.5px;\n  background: linear-gradient(90deg, transparent, var(--yk-accent) 15%, var(--yk-accent) 85%, transparent);\n  opacity: 0.5;\n}\n\n/* gap eyes */\n.yk-gap-top .yk-ge,\n.yk-gap-bottom .yk-ge {\n  position: absolute;\n  border-radius: 50%;\n  background: radial-gradient(circle, var(--yk-accent), transparent 65%);\n  opacity: 0;\n  animation: yk-blink 5.5s ease-in-out infinite;\n}\n\n/* ===== main content area ===== */\n.yk-content {\n  flex: 1;\n  min-width: 0;\n  position: relative;\n  background: linear-gradient(160deg, #1C0C2E, #221240 40%, #1A0A28);\n  padding: 12px 18px 14px;\n  word-break: break-word;\n  overflow-wrap: break-word;\n}\n\n/* subtle diamond pattern */\n.yk-content::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background-image:\n    linear-gradient(45deg, rgba(100,40,120,0.04) 25%, transparent 25%),\n    linear-gradient(-45deg, rgba(100,40,120,0.04) 25%, transparent 25%),\n    linear-gradient(45deg, transparent 75%, rgba(100,40,120,0.04) 75%),\n    linear-gradient(-45deg, transparent 75%, rgba(100,40,120,0.04) 75%);\n  background-size: 16px 16px;\n  background-position: 0 0, 0 8px, 8px -8px, -8px 0;\n  pointer-events: none;\n  opacity: 0.5;\n}\n\n/* red ribbon accent at very top */\n.yk-content::after {\n  content: '';\n  position: absolute;\n  top: 0; left: 0; right: 0;\n  height: 1.5px;\n  background: linear-gradient(90deg, var(--yk-ribbon), rgba(184,59,46,0.3) 70%, transparent);\n  opacity: 0.6;\n}\n\n/* ===== header ===== */\n.yk-header {\n  display: flex;\n  align-items: center;\n  margin-bottom: 8px;\n  position: relative;\n  z-index: 1;\n}\n\n/* mood eye indicator */\n.yk-mood-eye {\n  width: 14px;\n  height: 8px;\n  border-radius: 50%;\n  background: var(--yk-accent);\n  position: relative;\n  display: inline-block;\n  margin-right: 8px;\n  flex-shrink: 0;\n  opacity: 0.7;\n  filter: drop-shadow(0 0 4px var(--yk-main));\n}\n.yk-mood-eye::after {\n  content: '';\n  position: absolute;\n  top: 50%; left: 50%;\n  width: 5px; height: 7px;\n  background: var(--yk-main);\n  border-radius: 50%;\n  transform: translate(-50%,-50%);\n}\n\n.yk-name {\n  font-size: 1em;\n  font-weight: 600;\n  color: var(--yk-accent);\n  text-shadow: 0 0 8px rgba(100,40,120,0.5);\n  letter-spacing: 2px;\n}\n\n.yk-line {\n  flex: 1;\n  height: 1px;\n  margin-left: 12px;\n  background: linear-gradient(90deg, var(--yk-accent) 0%, rgba(100,40,120,0.2) 60%, transparent);\n  opacity: 0.35;\n}\n\n/* ===== content ===== */\n.yk-text {\n  position: relative;\n  z-index: 1;\n  font-size: 1em;\n  line-height: 1.8;\n  color: var(--yk-text);\n  text-shadow: 0 1px 3px rgba(0,0,0,0.7);\n}\n\n/* ===== animations ===== */\n@keyframes yk-blink {\n  0%, 36%, 46%, 86%, 100% { opacity: 0; }\n  41% { opacity: var(--yk-eye-c); }\n  56%, 82% { opacity: calc(var(--yk-eye-c) * 0.6); }\n}\n</style>",
