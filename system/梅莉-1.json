{
    "id": "fe9116a0-1b1d-4ed9-be11-a167c8034e03",
    "scriptName": "梅莉 (阿瓦隆女士) 专属正则美化 ",
    "findRegex": "/<merry name=\"(.*?)\">\\s*「\\s*([\\s\\S]*?)\\s*」\\s*<\\/merry>/g",
    "replaceString": "<div class=\"avalon-v5-container\">\n  <div class=\"avalon-v5-magic-layer\">\n    <div class=\"avalon-ring r1\"></div>\n    <div class=\"avalon-ring r2\"></div>\n    <div class=\"avalon-core\"></div>\n  </div>\n\n  <div class=\"avalon-v5-inner\">\n    <div class=\"avalon-v5-header\">\n      <div class=\"avalon-name-wrapper\">\n        <div class=\"avalon-sakura\"></div>\n        <span class=\"v5-name-cn\">$1</span>\n        <span class=\"v5-name-en\">Lady Avalon</span>\n      </div>\n      <div class=\"avalon-v5-line\"></div>\n    </div>\n\n    <div class=\"avalon-v5-content\">$2</div>\n  </div>\n</div>\n\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Shippori+Mincho:wght@400;600&display=swap');\n\n.avalon-v5-container{\n  --a-main:#ff8fd1;\n  --a-soft:#ffd6f2;\n  --a-glow:rgba(255,143,209,0.6);\n\n  position:relative;\n  margin:18px 5px;\n  border-radius:14px;\n  background:linear-gradient(145deg,rgba(30,8,45,0.97),rgba(60,15,75,0.95));\n  border:1px solid rgba(255,143,209,0.35);\n  box-shadow:\n    0 0 35px rgba(255,143,209,0.2),\n    inset 0 0 25px rgba(255,143,209,0.15);\n\n  font-family:'Shippori Mincho',serif;\n  overflow:hidden;\n  isolation:isolate;\n}\n\n/* 魔法阵 */\n\n.avalon-v5-magic-layer{\n  position:absolute;\n  top:50%;\n  right:-60px;\n  width:280px;\n  height:280px;\n  transform:translateY(-50%);\n  opacity:.35;\n  pointer-events:none;\n}\n\n.avalon-ring{\n  position:absolute;\n  top:50%;\n  left:50%;\n  border-radius:50%;\n  transform:translate(-50%,-50%);\n}\n\n.r1{\n  width:100%;\n  height:100%;\n  border:2px solid var(--a-main);\n  animation:avalon-spin 60s linear infinite;\n}\n\n.r2{\n  width:70%;\n  height:70%;\n  border:1px dashed var(--a-soft);\n  animation:avalon-spin 40s linear infinite reverse;\n}\n\n.avalon-core{\n  position:absolute;\n  top:50%;\n  left:50%;\n  width:40%;\n  height:40%;\n  transform:translate(-50%,-50%);\n  background:radial-gradient(circle,var(--a-main),transparent 70%);\n  border-radius:50%;\n  animation:avalon-pulse 4s infinite alternate;\n}\n\n/* 内容结构 */\n\n.avalon-v5-inner{\n  position:relative;\n  padding:14px 22px 18px 22px;\n  z-index:2;\n}\n\n/* 关键：压缩标题区 */\n\n.avalon-v5-header{\n  display:flex;\n  align-items:center;\n  margin-bottom:8px; /* 原来太大 */\n}\n\n.avalon-name-wrapper{\n  position:relative;\n  display:flex;\n  align-items:baseline;\n  gap:10px;\n  padding-left:16px;\n}\n\n/* 旋转樱花 */\n\n.avalon-sakura{\n  position:absolute;\n  left:0;\n  top:2px;\n  width:12px;\n  height:12px;\n  background:radial-gradient(circle,var(--a-soft),var(--a-main));\n  clip-path:polygon(\n    50% 0%, 61% 35%, 98% 35%, \n    68% 57%, 79% 91%, \n    50% 70%, 21% 91%, \n    32% 57%, 2% 35%, 39% 35%\n  );\n  animation:avalon-rotate 10s linear infinite;\n  box-shadow:0 0 8px var(--a-glow);\n}\n\n/* 名字缩小到三分之一视觉占比 */\n\n.v5-name-cn{\n  font-size:1.05em;   /* ↓ 原来1.25 */\n  color:var(--a-soft);\n  text-shadow:0 0 6px var(--a-main);\n}\n\n.v5-name-en{\n  font-family:'Cinzel',serif;\n  font-size:.6em;     /* ↓ 更小 */\n  letter-spacing:2px;\n  opacity:.75;\n  color:#fff;\n}\n\n/* 分隔线不再撑高 */\n\n.avalon-v5-line{\n  flex-grow:1;\n  height:1px;\n  margin-left:12px;\n  background:linear-gradient(90deg,var(--a-main),transparent);\n  opacity:.6;\n}\n\n/* 台词成为主体 */\n\n.avalon-v5-content{\n  font-size:1.05em;\n  line-height:1.8;\n  color:#ffeefc;\n  text-shadow:0 0 10px rgba(255,143,209,0.35);\n}\n\n/* 动画 */\n\n@keyframes avalon-spin{\n  from{transform:translate(-50%,-50%) rotate(0deg)}\n  to{transform:translate(-50%,-50%) rotate(360deg)}\n}\n\n@keyframes avalon-pulse{\n  0%{opacity:.4;transform:translate(-50%,-50%) scale(.9)}\n  100%{opacity:.8;transform:translate(-50%,-50%) scale(1.1)}\n}\n\n@keyframes avalon-rotate{\n  from{transform:rotate(0deg)}\n  to{transform:rotate(360deg)}\n}\n</style>",
