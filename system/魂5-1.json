    "replaceString": "<div class=\"souls5-hud-wrapper\">\n  <div class=\"souls5-sys-header\">\n    <div class=\"souls5-sys-text warning-red\">WARNING // DARK SPIRIT INVADED</div>\n  </div>\n\n  <div class=\"souls5-comms-panel\">\n    \n    <div class=\"souls5-panel-box souls5-avatar-box ember-mode\">\n      <div class=\"souls5-corner top-left\"></div>\n      <div class=\"souls5-corner top-right\"></div>\n      <div class=\"souls5-corner bottom-left\"></div>\n      <div class=\"souls5-corner bottom-right\"></div>\n      \n      <div class=\"souls5-avatar\"></div>\n      <div class=\"souls5-scanlines\"></div>\n    </div>\n\n    <div class=\"souls5-panel-box souls5-sound-box\">\n      <div class=\"souls5-corner top-left\"></div>\n      <div class=\"souls5-corner top-right\"></div>\n      <div class=\"souls5-corner bottom-left\"></div>\n      <div class=\"souls5-corner bottom-right\"></div>\n      \n      <div class=\"souls5-sound-label\">SOUND ONLY</div>\n      \n      <div class=\"souls5-waveform\">\n        <div class=\"wave-bar w1\"></div><div class=\"wave-bar w2\"></div><div class=\"wave-bar w3\"></div>\n        <div class=\"wave-bar w4\"></div><div class=\"wave-bar w5\"></div><div class=\"wave-bar w6\"></div>\n        <div class=\"wave-bar w7\"></div><div class=\"wave-bar w8\"></div><div class=\"wave-bar w9\"></div>\n        <div class=\"wave-bar w10\"></div><div class=\"wave-bar w11\"></div><div class=\"wave-bar w12\"></div>\n        <div class=\"wave-bar w13\"></div><div class=\"wave-bar w14\"></div><div class=\"wave-bar w15\"></div>\n      </div>\n      <div class=\"souls5-scanlines\"></div>\n    </div>\n\n    <div class=\"souls5-covenant-wrapper\">\n      <div class=\"souls5-covenant-box\">\n        <div class=\"souls5-corner top-left\"></div>\n        <div class=\"souls5-corner top-right\"></div>\n        <div class=\"souls5-corner bottom-left\"></div>\n        <div class=\"souls5-corner bottom-right\"></div>\n        \n        <div class=\"souls5-covenant-emblem\"></div>\n      </div>\n    </div>\n    \n  </div>\n\n  <div class=\"souls5-dialogue-section\">\n    <div class=\"souls5-speaker-name\">$1</div>\n    <div class=\"souls5-dialogue-line\"></div>\n    <div class=\"souls5-dialogue-text\">\n      $2\n    </div>\n  </div>\n</div>\n\n<style>\n@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap');\n\n.souls5-hud-wrapper {\n  position: relative;\n  margin: 15px 0;\n  padding: 12px 15px; \n  background-color: #05080a;\n  background-image:\n    radial-gradient(circle at 50% 50%, rgba(20, 30, 40, 0.8) 0%, #020304 100%),\n    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px);\n  background-size: 100% 100%, 100% 3px;\n  font-family: 'Share Tech Mono', 'Courier New', monospace;\n  color: #c5d0d8;\n  border-top: 1px solid rgba(197, 208, 216, 0.2);\n  border-bottom: 1px solid rgba(197, 208, 216, 0.2);\n  overflow: hidden;\n  box-shadow: inset 0 0 50px rgba(0,0,0,1);\n}\n\n.souls5-sys-header {\n  font-size: 0.6em;\n  letter-spacing: 2px;\n  margin-bottom: 12px; \n  border-bottom: 1px solid rgba(197, 208, 216, 0.1);\n  padding-bottom: 4px;\n  text-align: left;\n}\n\n.warning-red {\n  color: #ff3b3b;\n  font-weight: bold;\n  text-shadow: 0 0 8px rgba(255, 59, 59, 0.6);\n  animation: warning-blink 2.5s ease-in-out infinite;\n}\n\n@keyframes warning-blink {\n  0%, 100% { opacity: 1; text-shadow: 0 0 10px rgba(255, 59, 59, 0.8); }\n  50% { opacity: 0.6; text-shadow: 0 0 2px rgba(255, 59, 59, 0.3); }\n}\n\n.souls5-comms-panel {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 20px;\n  margin-bottom: 12px; \n  position: relative;\n}\n\n.souls5-comms-panel::before {\n  content: '';\n  position: absolute;\n  top: 50%;\n  left: 5%;\n  right: 5%;\n  height: 1px;\n  background: rgba(197, 208, 216, 0.1);\n  z-index: 0;\n}\n\n.souls5-panel-box {\n  position: relative;\n  background: rgba(10, 15, 20, 0.6);\n  border: 1px solid rgba(197, 208, 216, 0.3);\n  z-index: 1;\n  padding: 10px;\n  box-shadow: 0 0 10px rgba(0, 0, 0, 0.5), inset 0 0 15px rgba(100, 150, 200, 0.05);\n}\n\n.souls5-corner {\n  position: absolute;\n  width: 8px;\n  height: 8px;\n  border-color: rgba(255, 255, 255, 0.7);\n  border-style: solid;\n}\n.top-left { top: -1px; left: -1px; border-width: 1px 0 0 1px; }\n.top-right { top: -1px; right: -1px; border-width: 1px 1px 0 0; }\n.bottom-left { bottom: -1px; left: -1px; border-width: 0 0 1px 1px; }\n.bottom-right { bottom: -1px; right: -1px; border-width: 0 1px 1px 0; }\n\n.souls5-avatar-box {\n  width: 140px;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  flex-shrink: 0;\n}\n\n.ember-mode {\n  animation: ember-pulse 3s ease-in-out infinite;\n}\n\n@keyframes ember-pulse {\n  0%, 100% {\n    box-shadow: 0 0 10px rgba(0,0,0,0.5), inset 0 0 10px rgba(255, 80, 0, 0.2);\n    border-color: rgba(255, 80, 0, 0.3);\n  }\n  50% {\n    box-shadow: 0 0 18px rgba(255, 50, 0, 0.5), inset 0 0 25px rgba(255, 80, 0, 0.6);\n    border-color: rgba(255, 100, 0, 0.8);\n  }\n}\n\n.souls5-avatar {\n  width: 120px;\n  height: 120px;\n  background-image: url('https://iili.io/qq27U8P.jpg');\n  background-size: cover;\n  background-position: center;\n}\n\n.souls5-sound-box {\n  flex-grow: 1;\n  max-width: 300px;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  padding: 15px 20px;\n  flex-shrink: 1;\n}\n\n.souls5-sound-label {\n  font-size: 0.85em;\n  letter-spacing: 2px;\n  color: rgba(197, 208, 216, 0.7);\n  margin-bottom: 15px;\n}\n\n.souls5-waveform {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  height: 50px;\n  width: 100%;\n}\n\n.wave-bar {\n  width: 3px;\n  background-color: rgba(255, 255, 255, 0.8);\n  box-shadow: 0 0 4px rgba(255, 255, 255, 0.5);\n  animation: souls5-wave 1.2s ease-in-out infinite alternate;\n}\n\n.w1 { height: 20%; animation-delay: 0.1s; } .w2 { height: 60%; animation-delay: 0.4s; }\n.w3 { height: 30%; animation-delay: 0.2s; } .w4 { height: 80%; animation-delay: 0.7s; }\n.w5 { height: 40%; animation-delay: 0.3s; } .w6 { height: 90%; animation-delay: 0.1s; }\n.w7 { height: 20%; animation-delay: 0.8s; } .w8 { height: 100%; animation-delay: 0.5s; }\n.w9 { height: 50%; animation-delay: 0.2s; } .w10{ height: 70%; animation-delay: 0.6s; }\n.w11{ height: 30%; animation-delay: 0.9s; } .w12{ height: 80%; animation-delay: 0.3s; }\n.w13{ height: 40%; animation-delay: 0.1s; } .w14{ height: 60%; animation-delay: 0.4s; }\n.w15{ height: 20%; animation-delay: 0.7s; }\n\n@keyframes souls5-wave {\n  0% { transform: scaleY(0.1); }\n  100% { transform: scaleY(1); }\n}\n\n.souls5-covenant-wrapper {\n  width: 100px;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  flex-shrink: 0;\n  padding: 5px;\n  z-index: 1;\n}\n\n.souls5-covenant-box {\n  position: relative;\n  width: 66px;\n  height: 66px;\n  background: rgba(10, 15, 20, 0.6);\n  border: 1px solid rgba(197, 208, 216, 0.3);\n  transform: rotate(45deg);\n  display: flex;\n  justify-content: center;\n  align-items: center;\n}\n\n.souls5-covenant-emblem {\n  width: 44px;\n  height: 44px;\n  transform: rotate(-45deg);\n  background-image: url('https://iili.io/qq3D129.png');\n  background-size: cover;\n  background-position: center;\n  background-repeat: no-repeat;\n  position: relative;\n  overflow: hidden;\n}\n\n.souls5-scanlines {\n  position: absolute;\n  inset: 0;\n  background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.3) 2px, rgba(0,0,0,0.3) 4px);\n  pointer-events: none;\n  z-index: 5;\n}\n\n.souls5-dialogue-section {\n  text-align: center;\n  margin-top: 0px;\n}\n\n.souls5-speaker-name {\n  font-size: 0.85em;\n  color: rgba(255, 255, 255, 0.6);\n  letter-spacing: 2px;\n  margin-bottom: 4px; \n  text-transform: uppercase;\n}\n\n.souls5-dialogue-line {\n  height: 1px;\n  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.4) 15%, rgba(255,255,255,0.4) 85%, transparent 100%);\n  width: 60%;\n  margin: 0 auto 8px auto;\n}\n\n.souls5-dialogue-text {\n  font-size: 1.05em;\n  line-height: 1.5;\n  color: #fff;\n  text-shadow: 0 0 4px rgba(255,255,255,0.4);\n  max-width: 85%;\n  margin: 0 auto;\n  white-space: pre-wrap;\n  word-break: break-word;\n}\n\n@media only screen and (max-width: 600px) {\n  .souls5-hud-wrapper { padding: 10px 8px; margin: 10px 0; }\n  .souls5-comms-panel { flex-direction: column; align-items: center; gap: 10px; margin-bottom: 10px; }\n  .souls5-comms-panel::before { display: none; }\n  .souls5-avatar-box { width: 104px; }\n  .souls5-avatar { width: 88px; height: 88px; }\n  .souls5-sound-box { width: 100%; max-width: none; box-sizing: border-box; }\n  .souls5-covenant-wrapper { width: 80px; padding: 0px; }\n  .souls5-covenant-box { width: 50px; height: 50px; }\n  .souls5-covenant-emblem { width: 34px; height: 34px; }\n  .souls5-dialogue-line { width: 85%; }\n  \n \n  .souls5-dialogue-text {\n    font-size: 0.95em;\n    max-width: 95%;\n    text-align: left;\n    padding: 0 10px;\n  }\n}\n</style>",
