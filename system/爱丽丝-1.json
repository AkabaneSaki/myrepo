or='middle' fill='%23000000'%3E%E2%99%A5%3C/text%3E%3Ctext x='48' y='56' font-size='26' font-family='serif' text-anchor='middle' fill='%23000000'%3E%E2%99%A6%3C/text%3E%3C/svg%3E\");\n  background-size: 64px 64px;\n  border-style: solid;\n  border-width: 16px; \n  border-image-source: url('https://iili.io/qq9gMVR.png');\n  border-image-slice: 16; \n  border-image-repeat: repeat;\n  image-rendering: pixelated; \n  padding: 0px; \n  min-height: 96px; \n  box-shadow: inset 0 0 0 2px rgba(0,0,0,0.5), inset 0 0 20px rgba(0,0,0,0.8), 0 4px 10px rgba(0,0,0,0.6);\n}\n.bs-alice-portrait {\n  width: 96px; \n  height: 96px;\n  background-image: url('https://iili.io/qq9pLoN.png'); \n  background-position: left bottom; \n  background-repeat: no-repeat;\n  background-size: contain;\n  flex-shrink: 0; \n}\n.face-黑化 {\n  background-image: url('https://iili.io/qqH98va.png') !important; \n}\n.bs-alice-text {\n  flex-grow: 1;\n  font-size: 1.1em;\n  line-height: 1.7;\n  text-shadow: 2px 2px 0 #000, -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 0px 2px 0 #000, 2px 0px 0 #000;\n  white-space: pre-wrap;\n  word-break: break-word;\n  align-self: flex-start; \n  padding: 16px 20px 16px 16px; \n}\n@media only screen and (max-width: 600px) {\n  .bs-alice-wrapper {\n    margin: 25px 2px 10px 2px; \n  }\n  .bs-alice-nametag {\n    top: -16px; \n    left: 10px;\n    border-width: 10px; \n    padding: 2px 8px;\n    font-size: 12px;\n  }\n  .bs-alice-dialog {\n    border-width: 12px; \n    min-height: auto; \n    flex-direction: column; \n    align-items: center; \n  }\n  .bs-alice-portrait {\n    width: 80px; \n    height: 80px;\n    background-position: center bottom; \n    margin-top: 12px; \n  }\n  .bs-alice-text {\n    font-size: 1em; \n    width: 100%;\n    box-sizing: border-box;\n    padding: 10px 15px 15px 15px; \n  }\n}\n</style>",
